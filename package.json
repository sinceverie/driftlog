{
  "name": "driftlog",
  "version": "0.1.0",
  "description": "A CLI tool that detects and summarizes config drift between environments using structured diffs.",
  "main": "dist/index.js",
  "bin": {
    "driftlog": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "deep-diff": "^1.0.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/deep-diff": "^1.0.5",
    "@types/jest": "^29.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
